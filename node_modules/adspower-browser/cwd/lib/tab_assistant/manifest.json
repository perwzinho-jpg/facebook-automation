{
  "manifest_version": 3,
  "name": "AdsPower tabs",
  "version": "1.0.4",
  "description": "AdsPower tabs manager",
  "background": {
    "service_worker": "./background.mjs"
  },
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "cookies",
    "notifications",
    "declarativeNetRequest",
    "management"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "key": ""
}
